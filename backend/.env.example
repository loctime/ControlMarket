# JSON completo del service account de Firebase (una sola línea, sin saltos).
# Se obtiene en Firebase Console → Configuración → Cuentas de servicio → Generar nueva clave privada.
FIREBASE_SERVICE_ACCOUNT_JSON=

# Origen permitido para CORS (URL del frontend). Ej: https://controlmarket.vercel.app
# En desarrollo local: http://localhost:5173
ALLOWED_ORIGIN=http://localhost:5173

# Puerto del servidor (Vercel/Render lo inyectan automáticamente).
PORT=3001
