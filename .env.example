VITE_FIREBASE_API_KEY=your_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# Opcional: URL del API si corrés el backend en otro host.
# En Vercel (serverless en /api/) dejar vacío — usa same-origin.
# VITE_API_URL=

# Service account de Firebase (JSON completo en una sola línea) — SERVER ONLY.
# Necesario para las serverless functions en /api/. Configurar en Vercel como
# env var del proyecto; NO exponer al cliente.
FIREBASE_SERVICE_ACCOUNT_JSON=
